# Postgres — Project Settings → Database → Connection string (session mode)
DATABASE_URL=""

# Postgres session-mode con sslmode — per prisma db push / migrate
DIRECT_URL=""

# JWT — stringa casuale lunga (es. openssl rand -base64 64)
JWT_SECRET=""

# Google OAuth — Web Client ID da Google Cloud Console
GOOGLE_CLIENT_ID=""

